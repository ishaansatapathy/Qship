# Copy every KEY into Vercel → qship-api → Settings → Environment Variables (Production)
# Replace COPY_FROM_LOCAL with values from your root .env file

DATABASE_URL=COPY_FROM_LOCAL
BASE_URL=https://repoapi-production-adfe.up.railway.app
CLIENT_URL=https://qship.ishaandev.co.in
BETTER_AUTH_SECRET=SAME_AS_WEB_VERCEL_PROJECT
BETTER_AUTH_URL=https://qship.ishaandev.co.in
NODE_ENV=production

OPENAI_API_KEY=COPY_FROM_LOCAL
OPENAI_MODEL=gpt-4o-mini
PUBLIC_OPENAPI_DOCS=true

DEMO_LOGIN_ENABLED=false
# Enable only on staging/local — production disables demo bootstrap + self-approve bypass
# DEMO_USER_EMAIL=demo@qship.dev
# DEMO_USER_PASSWORD=DemoPass123!

# Required for production ship — POST JSON { event: "feature.shipped", featureId, ... }
SHIP_DEPLOY_WEBHOOK_URL=COPY_FROM_LOCAL_OR_VERCEL_DEPLOY_HOOK
# ALLOW_SIMULATED_DEPLOY=true

GITHUB_APP_ID=COPY_FROM_LOCAL
GITHUB_APP_SLUG=COPY_FROM_LOCAL
GITHUB_APP_PRIVATE_KEY=COPY_FROM_LOCAL
GITHUB_WEBHOOK_SECRET=COPY_FROM_LOCAL

RAZORPAY_KEY_ID=COPY_FROM_LOCAL
RAZORPAY_KEY_SECRET=COPY_FROM_LOCAL
RAZORPAY_WEBHOOK_SECRET=COPY_FROM_LOCAL

SHIPFLOW_INTAKE_WEBHOOK_SECRET=COPY_FROM_LOCAL

# Slack — incoming webhook for approve/ship notifications (#product-shipping)
SLACK_WEBHOOK_URL=COPY_FROM_LOCAL_OR_SLACK_INCOMING_WEBHOOK

INNGEST_EVENT_KEY=COPY_FROM_LOCAL
INNGEST_SIGNING_KEY=COPY_FROM_LOCAL

SHIPFLOW_MCP_API_KEY=COPY_FROM_LOCAL_OR_GENERATE
SHIPFLOW_MCP_USER_ID=COPY_FROM_LOCAL_OR_SKIP

LOGGER_LEVEL=info
