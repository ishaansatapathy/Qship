{
  "name": "shipflow-ai",
  "private": true,
  "scripts": {
    "build": "dotenv -v NODE_ENV=production -- turbo build",
    "dev": "dotenv -- turbo dev",
    "db:generate": "dotenv -- turbo db:generate",
    "db:migrate": "dotenv -- turbo db:migrate",
    "db:seed": "dotenv -- turbo db:seed",
    "db:up": "docker compose up -d postgresdb",
    "inngest:dev": "pnpm dlx inngest-cli@latest dev -u http://localhost:8000/api/inngest",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "verify:prod": "node scripts/verify-production.mjs"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.7.2",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
