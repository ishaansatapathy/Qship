# ── Linguist language overrides ─────────────────────────────────────────────
# These files are config/tooling — exclude from GitHub language stats.

# Lockfiles and generated manifests
pnpm-lock.yaml         linguist-generated=true
package-lock.json      linguist-generated=true
yarn.lock              linguist-generated=true

# ESLint flat configs (tooling, not app source)
eslint.config.js       linguist-vendored=true
**/eslint.config.js    linguist-vendored=true

# Bundler / formatter configs
prettier.config.js     linguist-vendored=true
postcss.config.mjs     linguist-vendored=true
next.config.js         linguist-vendored=true

# Build scripts
scripts/prepare-deploy.mjs              linguist-vendored=true
apps/api/scripts/vercel-postbuild.mjs  linguist-vendored=true

# Shared ESLint config package (tooling)
packages/eslint-config/**  linguist-vendored=true

# Next.js env validation (JS but auto-generated pattern)
apps/web/env.js        linguist-vendored=true
