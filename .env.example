# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dev

# API
PORT=8000
BASE_URL=http://localhost:8000
CLIENT_URL=http://localhost:3000
API_INTERNAL_URL=http://localhost:8000
NODE_ENV=development

# Web
NEXT_PUBLIC_API_URL=/trpc

# BetterAuth
BETTER_AUTH_SECRET=change-me-min-32-chars-long-secret
BETTER_AUTH_URL=http://localhost:3000

# Google sign-in (BetterAuth) — also accepts GOOGLE_OAUTH_* aliases
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# AI (Vercel AI SDK)
OPENAI_API_KEY=

# GitHub OAuth sign-in (BetterAuth — optional, separate from GitHub App)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub App (repos, PRs, webhooks)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Logger
LOGGER_LEVEL=debug
