# Database — local Docker (dev) OR Neon (production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dev
# Neon pooled connection (app runtime) — paste from Neon dashboard → Connection details → Pooled
# DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX-pooler.region.aws.neon.tech/neondb?sslmode=require
# Neon direct connection (migrations) — paste Direct connection string
DATABASE_URL_UNPOOLED=postgresql://postgres:postgres@localhost:5432/dev
# DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@ep-XXXX.region.aws.neon.tech/neondb?sslmode=require

# API
PORT=8000
BASE_URL=http://localhost:8000
CLIENT_URL=http://localhost:3000
API_INTERNAL_URL=http://localhost:8000
NODE_ENV=development

# Web
NEXT_PUBLIC_API_URL=/trpc
# Production display (billing webhook hint) — e.g. https://repoapi-production-adfe.up.railway.app
NEXT_PUBLIC_API_BASE_URL=

# BetterAuth — generate: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-min-32-chars-long-secret
BETTER_AUTH_URL=http://localhost:3000

# Google sign-in (BetterAuth) — also accepts GOOGLE_OAUTH_* aliases
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# AI (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# GitHub OAuth sign-in (BetterAuth — optional, separate from GitHub App)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Ship deploy webhook — POST JSON when a feature is marked shipped (optional)
SHIP_DEPLOY_WEBHOOK_URL=

# Ship release — optional deploy webhook fired after PR merge on Mark shipped
SHIP_DEPLOY_WEBHOOK_URL=

# GitHub App (repos, PRs, webhooks)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# Demo login (judges / hackathon — enable for one-click access)
DEMO_LOGIN_ENABLED=true
DEMO_USER_EMAIL=demo@qship.dev
DEMO_USER_PASSWORD=DemoPass123!
NEXT_PUBLIC_DEMO_LOGIN_ENABLED=true
NEXT_PUBLIC_DEMO_USER_EMAIL=demo@qship.dev
SEED_USER_EMAIL=demo@qship.dev
SEED_DEMO_PASSWORD=DemoPass123!

# Demo AI limits per browser session (demo account only)
NEXT_PUBLIC_DEMO_AGENT_LIMIT=3
NEXT_PUBLIC_DEMO_CALENDAR_LIMIT=3
NEXT_PUBLIC_DEMO_MAIL_LIMIT=3

# MCP headless access (optional — bound to one user)
SHIPFLOW_MCP_API_KEY=
SHIPFLOW_MCP_USER_ID=

# Multi-channel intake webhook (email / support / calls → feature requests)
SHIPFLOW_INTAKE_WEBHOOK_SECRET=

# Slack — incoming webhook for approve/ship notifications (optional; simulates when unset)
SLACK_WEBHOOK_URL=

# Scalar / OpenAPI docs in production
PUBLIC_OPENAPI_DOCS=true

# Inngest (planned)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Razorpay — https://dashboard.razorpay.com/app/keys (use Test Mode keys locally)
# Test card: 4111 1111 1111 1111 · any future expiry · any CVV · OTP 123456
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_test_key_secret
# Webhook secret — Dashboard → Webhooks → create → URL: https://YOUR-API/webhooks/razorpay
RAZORPAY_WEBHOOK_SECRET=

# Logger
LOGGER_LEVEL=debug

# Legacy JWT (CI compatibility)
JWT_SECRET=dev-jwt-secret-min-16-chars
JWT_REFRESH_SECRET=dev-refresh-secret-min-16-chars
